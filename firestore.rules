rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to get current user's role
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isTeamLeader() {
      return getUserRole() == 'Team Leader';
    }

    function isCoordinator() {
      return getUserRole() == 'Coordinator';
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Users Collection
    match /users/{userId} {
      // Base read for directory. (Note: Firestore does not support field-level read 
      // rules natively without client query projecting, so we allow base read).
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isTeamLeader());
    }

    // Events Collection & Subcollections
    match /events/{eventId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (isTeamLeader() || isCoordinator());
      allow update: if request.auth != null && (isTeamLeader() || isCoordinator());
      allow delete: if request.auth != null && isTeamLeader();

      match /tasks/{taskId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && (isTeamLeader() || isCoordinator() || request.auth.uid in get(/databases/$(database)/documents/events/$(eventId)).data.team);
      }
      match /messages/{messageId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
      }
      match /docs/{docId} {
        allow read, write: if request.auth != null;
      }
      match /meetings/{meetId} {
        allow read, write: if request.auth != null;
      }
    }

    // Expenses Collection
    match /expenses/{expenseId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (isTeamLeader() || isCoordinator());
      // Only Team Leaders can update the status to 'reimbursed' (or settle)
      allow update: if request.auth != null && isTeamLeader();
      allow delete: if request.auth != null && isTeamLeader();
    }

    // Hours Log Collection
    match /hours_log/{logId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      
      // Approving rules: TL can approve any. Coordinator can ONLY approve if target user is a Rep.
      allow update: if request.auth != null && (
        isTeamLeader() || 
        (isCoordinator() && get(/databases/$(database)/documents/users/$(resource.data.userId)).data.role == 'Representative')
      );
      allow delete: if request.auth != null && isTeamLeader();
    }
    
    // Channels Collection (Global chats/tasks if any)
    match /channels/{channelId}/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
